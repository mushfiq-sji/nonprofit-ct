# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key-here"

# ===== EDGE FUNCTION ENVIRONMENT VARIABLES =====
# These should be set in Supabase Dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/functions
# Click "Secrets" to add these values

# AI Services (CRITICAL - Required for all AI features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Alternative AI Provider (Optional)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxx

# Email Notifications
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Zoom Integration (Optional - for meeting sync)
# Get from: https://marketplace.zoom.us/
ZOOM_CLIENT_ID=xxxxxxxxxxxxx
ZOOM_CLIENT_SECRET=xxxxxxxxxxxxx
ZOOM_ACCOUNT_ID=xxxxxxxxxxxxx

# Google OAuth & Drive (Optional - for Drive integration)
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxx
GOOGLE_API_KEY=xxxxxxxxxxxxx

# Slack Notifications (Optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Microsoft Azure AD SSO (Optional - for Microsoft Teams/SSO)
# Get from: https://portal.azure.com > App Registrations
VITE_MICROSOFT_CLIENT_ID=your-application-client-id
VITE_MICROSOFT_DIRECTORY_ID=your-directory-tenant-id
VITE_MICROSOFT_REDIRECT_URI=http://localhost:8080
VITE_MICROSOFT_LOGOUT_URI=http://localhost:8080/login

# ===== MODULE TOGGLES (Build-time) =====
# Set to "false" to exclude a module from the build entirely.
# At runtime, modules can also be toggled via the Admin panel (app_modules table).
# All modules default to "true" if not specified.
VITE_MODULE_EOS=true
VITE_MODULE_MEETINGS=true
VITE_MODULE_PROJECTS=true
VITE_MODULE_ACTIONS=true
VITE_MODULE_BUSINESS_DEV=true
VITE_MODULE_KNOWLEDGE=true
VITE_MODULE_PRODUCTIVITY=true

# Auto-set by Supabase (verify these exist in dashboard)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — local dev only: direct Lovable gateway from browser (usually NOT needed).
# LOVABLE_API_KEY in Lovable Secrets cannot be viewed after save — only Rotate shows a new value once.
# Prefer: deploy event-intelligence Sonnet mode on Lovable; localhost calls that edge function instead.
# VITE_LOVABLE_API_KEY=only-if-you-captured-after-rotate

# Required for npm run seed:nonprofit when not using SQL Editor (pick one):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# — OR service role only (uses REST API; same SUPABASE_SERVICE_ROLE_KEY above)
